{
  "version": "1.0",
  "rules": [
    {
      "id": "builtin-rm-rf-root",
      "name": "rm -rf root",
      "type": "BLACKLIST",
      "pattern": "\\brm\\s+.*-rf.*\\s+/",
      "riskLevel": "DANGER",
      "description": "递归删除根目录",
      "enabled": true
    },
    {
      "id": "builtin-mkfs",
      "name": "mkfs",
      "type": "BLACKLIST",
      "pattern": "\\bmkfs\\..*",
      "riskLevel": "DANGER",
      "description": "格式化文件系统",
      "enabled": true
    },
    {
      "id": "builtin-dd",
      "name": "dd dangerous",
      "type": "BLACKLIST",
      "pattern": "\\bdd.*of=/dev/",
      "riskLevel": "DANGER",
      "description": "dd写入设备",
      "enabled": true
    },
    {
      "id": "builtin-reboot",
      "name": "reboot",
      "type": "BLACKLIST",
      "pattern": "\\breboot\\b|\\bshutdown\\b|\\binit\\s+0\\b|\\binit\\s+6\\b|\\bsystemctl.*poweroff|\\bsystemctl.*reboot|\\bhalt\\b|\\bpoweroff\\b",
      "riskLevel": "DANGER",
      "description": "系统重启/关机",
      "enabled": true
    },
    {
      "id": "builtin-rm-rf",
      "name": "rm -rf",
      "type": "BLACKLIST",
      "pattern": "\\brm\\s+.*-rf",
      "riskLevel": "RISK",
      "description": "递归删除",
      "enabled": true
    },
    {
      "id": "builtin-cp-mv",
      "name": "cp/mv",
      "type": "BLACKLIST",
      "pattern": "\\bcp\\s+-f|\\bmv\\s+",
      "riskLevel": "RISK",
      "description": "复制/移动文件",
      "enabled": true
    },
    {
      "id": "builtin-touch-mkdir",
      "name": "touch/mkdir",
      "type": "BLACKLIST",
      "pattern": "\\btouch\\s+|\\bmkdir\\s+-p",
      "riskLevel": "RISK",
      "description": "创建文件/目录",
      "enabled": true
    },
    {
      "id": "builtin-sed-awk-perl",
      "name": "sed/awk/perl in-place",
      "type": "BLACKLIST",
      "pattern": "\\bsed\\s+-i|\\bawk\\s+-i.*inplace|\\bperl\\s+-i",
      "riskLevel": "RISK",
      "description": "原地修改文件",
      "enabled": true
    },
    {
      "id": "builtin-chmod",
      "name": "chmod dangerous",
      "type": "BLACKLIST",
      "pattern": "\\bchmod\\s+777|\\bchmod\\s+-R",
      "riskLevel": "RISK",
      "description": "危险权限修改",
      "enabled": true
    },
    {
      "id": "builtin-chown",
      "name": "chown/chgrp",
      "type": "BLACKLIST",
      "pattern": "\\bchown\\s+-R|\\bchgrp\\s+-R",
      "riskLevel": "RISK",
      "description": "递归修改所有者",
      "enabled": true
    },
    {
      "id": "builtin-kill",
      "name": "kill -9",
      "type": "BLACKLIST",
      "pattern": "\\bkill\\s+-9|\\bpkill\\s+-9|\\bkillall\\s+-9",
      "riskLevel": "RISK",
      "description": "强制终止进程",
      "enabled": true
    },
    {
      "id": "builtin-file-write",
      "name": "file write redirection",
      "type": "BLACKLIST",
      "pattern": "\\s*>\\s*[^\\s]|\\s*1>\\s*[^\\s]|\\s*2>\\s*[^\\s]|\\s*>>\\s*[^\\s]",
      "riskLevel": "RISK",
      "description": "重定向写文件",
      "enabled": true
    },
    {
      "id": "builtin-reverse-shell",
      "name": "reverse shell detection",
      "type": "BLACKLIST",
      "pattern": "/dev/(tcp|udp)/|\\bnc\\s+.*\\d+\\.\\d+\\.\\d+\\.\\d+|\\btelnet\\s+.*\\d+\\.\\d+\\.\\d+\\.\\d+|\\bbash\\s+-i\\s+>&\\s*/dev/tcp/",
      "riskLevel": "DANGER",
      "description": "反弹 Shell 检测（/dev/tcp、nc、telnet等）",
      "enabled": true
    },
    {
      "id": "builtin-pipe-dangerous",
      "name": "dangerous pipe usage",
      "type": "BLACKLIST",
      "pattern": "\\|.*\\b(nc|telnet|bash|sh|zsh|python|perl|ruby)\\b|\\|.*>/dev/(tcp|udp)/",
      "riskLevel": "DANGER",
      "description": "危险管道操作（管道后接 nc/telnet/shell 等）",
      "enabled": true
    },
    {
      "id": "builtin-suspicious-delimiter",
      "name": "suspicious command delimiter",
      "type": "BLACKLIST",
      "pattern": "\\|.*\\|.*\\||;.*;.*;|&.*&.*&",
      "riskLevel": "RISK",
      "description": "可疑的多重重定向/分隔符",
      "enabled": true
    },
    {
      "id": "builtin-ls",
      "name": "ls",
      "type": "WHITELIST",
      "pattern": "^\\s*ls\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "查看目录",
      "enabled": true
    },
    {
      "id": "builtin-cat",
      "name": "cat",
      "type": "WHITELIST",
      "pattern": "^\\s*cat\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "查看文件内容",
      "enabled": true
    },
    {
      "id": "builtin-echo",
      "name": "echo/printf",
      "type": "WHITELIST",
      "pattern": "^\\s*echo\\b(?!.*[;|&<>])|^\\s*printf\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "输出文本",
      "enabled": true
    },
    {
      "id": "builtin-info",
      "name": "info commands",
      "type": "WHITELIST",
      "pattern": "^\\s*pwd\\b(?!.*[;|&<>])|^\\s*whoami\\b(?!.*[;|&<>])|^\\s*id\\b(?!.*[;|&<>])|^\\s*date\\b(?!.*[;|&<>])|^\\s*uptime\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "系统信息查询",
      "enabled": true
    },
    {
      "id": "builtin-process-view",
      "name": "process view",
      "type": "WHITELIST",
      "pattern": "^\\s*ps\\b(?!.*[;|&<>])|^\\s*top\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "进程查看",
      "enabled": true
    },
    {
      "id": "builtin-file-view",
      "name": "file view",
      "type": "WHITELIST",
      "pattern": "^\\s*head\\b(?!.*[;|&<>])|^\\s*tail\\b(?!.*[;|&<>])|^\\s*less\\b(?!.*[;|&<>])|^\\s*more\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "文件内容查看",
      "enabled": true
    },
    {
      "id": "builtin-search",
      "name": "search",
      "type": "WHITELIST",
      "pattern": "^\\s*grep\\b(?!.*[;|&<>])|^\\s*find\\b(?!.*[;|&<>])",
      "riskLevel": "SAFE",
      "description": "搜索",
      "enabled": true
    }
  ]
}
